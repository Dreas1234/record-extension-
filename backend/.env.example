# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=meetrecord-recordings

# ─── Auth mode: "simple" (env-based credentials) or "keycloak" ───────────────
AUTH_MODE=simple
AUTH_TOKEN_SECRET=change-me-to-a-random-secret

# ─── Simple auth credentials (used when AUTH_MODE=simple) ─────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_DISPLAY_NAME=Admin User

# ─── Keycloak (used when AUTH_MODE=keycloak) ──────────────────────────────────
KEYCLOAK_URL=https://keycloak.yourcompany.com
KEYCLOAK_REALM=meetrecord
KEYCLOAK_CLIENT_ID=meetrecord-backend
KEYCLOAK_CLIENT_SECRET=
